# Plane.so Configuration
# Copy this file to plane.env and update values

# ===========================================
# DOMAIN (REQUIRED)
# ===========================================
APP_DOMAIN=plane.example.com

# ===========================================
# VERSION
# ===========================================
APP_RELEASE=stable

# ===========================================
# SECURITY (CHANGE THESE IN PRODUCTION!)
# ===========================================
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
LIVE_SERVER_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ===========================================
# DATABASE
# ===========================================
POSTGRES_USER=plane
POSTGRES_PASSWORD=CHANGE_ME_secure_password
POSTGRES_DB=plane

# ===========================================
# RABBITMQ
# ===========================================
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=CHANGE_ME_secure_password
RABBITMQ_VHOST=plane

# ===========================================
# MINIO (S3 Storage)
# ===========================================
AWS_ACCESS_KEY_ID=CHANGE_ME_minio_access_key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret_key

# ===========================================
# OPTIONAL
# ===========================================
DEBUG=0
GUNICORN_WORKERS=2
FILE_SIZE_LIMIT=26214400
API_KEY_RATE_LIMIT=60/minute
