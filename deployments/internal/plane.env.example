## Core
DEBUG=false
SECRET_KEY=change-me

## Public URLs
WEB_URL=https://plane.example.com
ADMIN_URL=https://plane.example.com
SPACE_URL=https://plane.example.com
API_URL=https://plane.example.com

## DB (DigitalOcean Managed Postgres)
DATABASE_URL=postgresql://plane_user:plane_password@db-host:25060/plane_db?sslmode=require
POSTGRES_USER=plane_user
POSTGRES_DB=plane_db
POSTGRES_PASSWORD=plane_password
POSTGRES_HOST=db-host
POSTGRES_PORT=25060
POSTGRES_SSLMODE=require

## Redis (local container by default)
REDIS_URL=redis://plane-redis:6379/0

## RabbitMQ (local container by default)
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=plane
RABBITMQ_VHOST=/
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672

## Storage (S3 / DO Spaces)
AWS_ACCESS_KEY_ID=do-spaces-key
AWS_SECRET_ACCESS_KEY=do-spaces-secret
AWS_S3_REGION_NAME=nyc3
AWS_S3_BUCKET_NAME=plane-uploads
AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
AWS_S3_CUSTOM_DOMAIN=plane-uploads.nyc3.digitaloceanspaces.com
USE_S3=true

## Misc
FILE_SIZE_LIMIT=5242880
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
